# ──────────────────────────────────────────────────────────────
#  TicketMandu Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── PostgreSQL — use DATABASE_URL OR individual vars ─────────
# Option A (recommended for production):
# DATABASE_URL=postgres://user:password@localhost:5432/ticketmandu

# Option B (local development):
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=ticketmandu
DB_SSL=false

# ── JWT ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_long_random_jwt_secret_here
JWT_REFRESH_SECRET=your_long_random_refresh_secret_here_different_from_above
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── File Upload ───────────────────────────────────────────────
MAX_FILE_SIZE=5mb

# ── Payment Gateways (Phase 8) ───────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# KHALTI_SECRET_KEY=your_khalti_secret_key
# ESEWA_SECRET_KEY=your_esewa_secret_key

# ── Email (Phase 4 — Email Verification) ─────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=noreply@ticketmandu.com

# ── Redis (Phase 12 — Real-time & Caching) ───────────────────
# REDIS_URL=redis://localhost:6379

# ── Cloudinary (Phase 15 — CDN Media Storage) ────────────────
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
