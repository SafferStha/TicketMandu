# Copy this file to .env and fill in your values

# Server
PORT=8000

# PostgreSQL (individual vars)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=ticketmandu

# Or use a connection string instead of individual vars:
# DATABASE_URL=postgres://user:password@localhost:5432/ticketmandu

# SSL (set to true only for managed DB providers like Supabase/Heroku)
DB_SSL=false

# JWT — use a long random secret in production
JWT_SECRET=your_jwt_secret_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
